<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AppBackdropColor">#08111C</Color>
    <Color x:Key="ShellBackgroundColor">#0E1826</Color>
    <Color x:Key="ShellStrokeColor">#20354C</Color>
    <Color x:Key="SurfaceColor">#132131</Color>
    <Color x:Key="SurfaceElevatedColor">#18283B</Color>
    <Color x:Key="SurfaceStrokeColor">#27425E</Color>
    <Color x:Key="PanelOverlayColor">#14314D</Color>
    <Color x:Key="SurfaceGridColor">#1C3149</Color>
    <Color x:Key="TextPrimaryColor">#F2F8FF</Color>
    <Color x:Key="TextSecondaryColor">#B7CCE1</Color>
    <Color x:Key="TextMutedColor">#88A7C6</Color>
    <Color x:Key="AccentColor">#6BC7FF</Color>
    <Color x:Key="AccentStrongColor">#B7ECFF</Color>
    <Color x:Key="AccentSoftColor">#153B59</Color>

    <SolidColorBrush x:Key="AppBackdropBrush" Color="{StaticResource AppBackdropColor}" />
    <SolidColorBrush x:Key="ShellBackgroundBrush" Color="{StaticResource ShellBackgroundColor}" />
    <SolidColorBrush x:Key="ShellStrokeBrush" Color="{StaticResource ShellStrokeColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceElevatedColor}" />
    <SolidColorBrush x:Key="SurfaceStrokeBrush" Color="{StaticResource SurfaceStrokeColor}" />
    <SolidColorBrush x:Key="PanelOverlayBrush" Color="{StaticResource PanelOverlayColor}" />
    <SolidColorBrush x:Key="SurfaceGridBrush" Color="{StaticResource SurfaceGridColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentStrongBrush" Color="{StaticResource AccentStrongColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}" />
</ResourceDictionary>
