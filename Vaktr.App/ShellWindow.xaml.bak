<Window
    x:Class="Vaktr.App.ShellWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Vaktr.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Vaktr">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Window.Resources>
        <DataTemplate x:Key="SummaryCardTemplate">
            <Border
                Width="290"
                Margin="0,0,18,18"
                Background="{ThemeResource SurfaceBrush}"
                BorderBrush="{ThemeResource SurfaceStrokeBrush}"
                BorderThickness="1"
                CornerRadius="24"
                Padding="18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Width="58" Height="58">
                        <Border
                            Background="{Binding AccentBrush}"
                            CornerRadius="18"
                            Opacity="0.22" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Bahnschrift"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="{Binding AccentBrush}"
                            Text="{Binding Glyph}" />
                    </Grid>

                    <StackPanel Grid.Column="1" Margin="16,0,0,0" Spacing="4">
                        <TextBlock
                            CharacterSpacing="50"
                            FontSize="11"
                            Foreground="{ThemeResource TextMutedBrush}"
                            Text="{Binding Title}" />
                        <TextBlock
                            FontFamily="Bahnschrift"
                            FontSize="28"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextPrimaryBrush}"
                            Text="{Binding Value}" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextSecondaryBrush}"
                            Text="{Binding Caption}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="PanelToggleTemplate">
            <CheckBox
                Content="{Binding Title}"
                IsChecked="{Binding IsVisible, Mode=TwoWay}"
                Style="{StaticResource DeckCheckBoxStyle}" />
        </DataTemplate>

        <DataTemplate x:Key="DashboardPanelTemplate">
            <controls:MetricDeck
                Width="430"
                Height="320"
                Margin="0,0,18,18"
                Panel="{Binding}" />
        </DataTemplate>
    </Window.Resources>

    <SplitView
        x:Name="SettingsSplitView"
        CompactPaneLength="0"
        DisplayMode="Overlay"
        IsPaneOpen="{Binding IsSettingsOpen, Mode=TwoWay}"
        OpenPaneLength="360"
        PanePlacement="Right">
        <SplitView.Pane>
            <Border
                Background="{ThemeResource SurfaceElevatedBrush}"
                BorderBrush="{ThemeResource SurfaceStrokeBrush}"
                BorderThickness="1,0,0,0">
                <ScrollViewer>
                    <StackPanel Padding="24" Spacing="16">
                        <StackPanel Spacing="6">
                            <TextBlock
                                FontFamily="Segoe UI Variable Display"
                                FontSize="26"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextPrimaryBrush}"
                                Text="Control deck" />
                            <TextBlock
                                Foreground="{ThemeResource TextSecondaryBrush}"
                                Text="Tune collection cadence, retention, storage, and which panels stay in the fight."
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <TextBlock CharacterSpacing="60" FontSize="12" Foreground="{ThemeResource TextMutedBrush}" Text="Scrape interval" />
                        <ComboBox DisplayMemberPath="Label" ItemsSource="{Binding IntervalOptions}" SelectedValue="{Binding SelectedIntervalSeconds, Mode=TwoWay}" SelectedValuePath="Value" Style="{StaticResource DeckComboBoxStyle}" />

                        <TextBlock CharacterSpacing="60" FontSize="12" Foreground="{ThemeResource TextMutedBrush}" Text="Graph window" />
                        <ComboBox DisplayMemberPath="Label" ItemsSource="{Binding WindowOptions}" SelectedValue="{Binding SelectedWindowMinutes, Mode=TwoWay}" SelectedValuePath="Value" Style="{StaticResource DeckComboBoxStyle}" />

                        <TextBlock CharacterSpacing="60" FontSize="12" Foreground="{ThemeResource TextMutedBrush}" Text="Retention" />
                        <ComboBox DisplayMemberPath="Label" ItemsSource="{Binding RetentionOptions}" SelectedValue="{Binding SelectedRetentionDays, Mode=TwoWay}" SelectedValuePath="Value" Style="{StaticResource DeckComboBoxStyle}" />

                        <TextBlock CharacterSpacing="60" FontSize="12" Foreground="{ThemeResource TextMutedBrush}" Text="Theme" />
                        <ComboBox DisplayMemberPath="Label" ItemsSource="{Binding ThemeOptions}" SelectedValue="{Binding SelectedTheme, Mode=TwoWay}" SelectedValuePath="Value" Style="{StaticResource DeckComboBoxStyle}" />

                        <TextBlock CharacterSpacing="60" FontSize="12" Foreground="{ThemeResource TextMutedBrush}" Text="Storage path" />
                        <TextBox Style="{StaticResource DeckTextBoxStyle}" Text="{Binding StorageDirectory, Mode=TwoWay}" />

                        <CheckBox Content="Launch Vaktr when Windows starts" IsChecked="{Binding LaunchOnStartup, Mode=TwoWay}" Style="{StaticResource DeckCheckBoxStyle}" />
                        <CheckBox Content="Minimize to tray when closing" IsChecked="{Binding MinimizeToTray, Mode=TwoWay}" Style="{StaticResource DeckCheckBoxStyle}" />

                        <StackPanel Spacing="8">
                            <TextBlock CharacterSpacing="60" FontSize="12" Foreground="{ThemeResource TextMutedBrush}" Text="Visible panels" />
                            <ItemsControl ItemTemplate="{StaticResource PanelToggleTemplate}" ItemsSource="{Binding PanelToggles}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Click="OnSaveSettingsClick" Content="Apply changes" Style="{StaticResource FilledButtonStyle}" />
                            <Button Click="OnSettingsClick" Content="Close deck" Style="{StaticResource GhostButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </SplitView.Pane>

        <SplitView.Content>
            <Grid x:Name="RootLayout" Background="{ThemeResource AppBackdropBrush}" Loaded="OnRootLoaded">
                <Ellipse Width="760" Height="760" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-220,-280,0,0" Fill="{ThemeResource AccentHaloBrush}" />
                <Ellipse Width="620" Height="620" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-160,-220" Fill="{ThemeResource WarningHaloBrush}" />

                <ScrollViewer>
                    <Grid Margin="18">
                        <Border
                            Background="{ThemeResource ShellBackgroundBrush}"
                            BorderBrush="{ThemeResource ShellStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="30"
                            Padding="24">
                            <StackPanel Spacing="24">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="12">
                                        <TextBlock CharacterSpacing="120" FontSize="12" Foreground="{ThemeResource AccentBrush}" Text="RIG TELEMETRY // LOCAL ONLY" />
                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                            <Border Width="54" Height="54" Background="{ThemeResource AccentSoftBrush}" CornerRadius="18">
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Bahnschrift" FontSize="26" FontWeight="SemiBold" Foreground="{ThemeResource AccentStrongBrush}" Text="V" />
                                            </Border>

                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock FontFamily="Segoe UI Variable Display" FontSize="32" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" Text="Vaktr" />
                                                <TextBlock Foreground="{ThemeResource TextSecondaryBrush}" Text="Sleek, local, gamer-friendly hardware watch with a durable history trail." TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="10" VerticalAlignment="Top">
                                        <Border Background="{ThemeResource SurfaceElevatedBrush}" BorderBrush="{ThemeResource SurfaceStrokeBrush}" BorderThickness="1" CornerRadius="18" Padding="14,10">
                                            <TextBlock FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" Text="{Binding StatusText}" />
                                        </Border>

                                        <Button Click="OnThemeQuickToggle" Content="Theme" Style="{StaticResource GhostButtonStyle}" />
                                        <Button Click="OnSettingsClick" Content="Deck" Style="{StaticResource GhostButtonStyle}" />
                                    </StackPanel>
                                </Grid>

                                <ItemsControl ItemTemplate="{StaticResource SummaryCardTemplate}" ItemsSource="{Binding SummaryCards}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapGrid MaximumRowsOrColumns="4" Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>

                                <StackPanel Spacing="6">
                                    <TextBlock CharacterSpacing="120" FontSize="12" Foreground="{ThemeResource AccentBrush}" Text="LIVE BOARD" />
                                    <TextBlock FontSize="14" Foreground="{ThemeResource TextSecondaryBrush}" Text="CPU, memory, disk, and network panels stay compact by default and can be expanded on demand." />
                                </StackPanel>

                                <ItemsControl ItemTemplate="{StaticResource DashboardPanelTemplate}" ItemsSource="{Binding DashboardPanels}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapGrid MaximumRowsOrColumns="3" Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>

                <Grid x:Name="ExpandedOverlay" Background="{ThemeResource OverlayScrimBrush}" Visibility="Collapsed">
                    <Border
                        Width="1040"
                        Height="680"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{ThemeResource ShellBackgroundBrush}"
                        BorderBrush="{ThemeResource ShellStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="28"
                        Padding="18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="4">
                                    <TextBlock CharacterSpacing="120" FontSize="12" Foreground="{ThemeResource AccentBrush}" Text="EXPANDED PANEL" />
                                    <TextBlock FontFamily="Segoe UI Variable Display" FontSize="24" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" Text="{Binding ExpandedPanel.Title, FallbackValue='Telemetry panel'}" />
                                </StackPanel>

                                <Button Grid.Column="1" Click="OnExpandedCloseClick" Content="Close" Style="{StaticResource GhostButtonStyle}" />
                            </Grid>

                            <controls:MetricDeck Grid.Row="1" Margin="0,18,0,0" IsExpandedView="True" Panel="{Binding ExpandedPanel}" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </SplitView.Content>
    </SplitView>
</Window>
