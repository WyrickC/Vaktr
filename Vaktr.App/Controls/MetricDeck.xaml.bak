<UserControl
    x:Class="Vaktr.App.Controls.MetricDeck"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Vaktr.App.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="Root">
    <Border
        x:Name="PanelCard"
        Background="{ThemeResource SurfaceBrush}"
        BorderBrush="{ThemeResource SurfaceStrokeBrush}"
        BorderThickness="1"
        CornerRadius="24"
        Padding="20"
        PointerEntered="OnPanelPointerEntered"
        PointerExited="OnPanelPointerExited">
        <Grid>
            <Border
                x:Name="HoverGlow"
                Background="{ThemeResource AccentHaloBrush}"
                CornerRadius="24"
                Opacity="0" />

            <Border
                Background="{ThemeResource PanelOverlayBrush}"
                CornerRadius="24"
                Opacity="0.48" />

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border
                                Background="{ThemeResource AccentSoftBrush}"
                                CornerRadius="999"
                                Padding="10,4">
                                <TextBlock
                                    FontFamily="Bahnschrift"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource AccentStrongBrush}"
                                    Text="{Binding Panel.Badge, ElementName=Root}" />
                            </Border>

                            <TextBlock
                                Margin="0,4,0,0"
                                CharacterSpacing="60"
                                FontSize="11"
                                Foreground="{ThemeResource TextMutedBrush}"
                                Text="{Binding Panel.FooterText, ElementName=Root}" />
                        </StackPanel>

                        <TextBlock
                            FontFamily="Segoe UI Variable Display"
                            FontSize="24"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextPrimaryBrush}"
                            Text="{Binding Panel.Title, ElementName=Root}" />

                        <TextBlock
                            FontFamily="Bahnschrift"
                            FontSize="30"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextPrimaryBrush}"
                            Text="{Binding Panel.CurrentValue, ElementName=Root}" />

                        <TextBlock
                            FontSize="13"
                            Foreground="{ThemeResource TextSecondaryBrush}"
                            Text="{Binding Panel.SecondaryValue, ElementName=Root}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Top">
                        <Button
                            x:Name="OneMinuteButton"
                            Click="OnRangeClick"
                            Content="1m"
                            Style="{StaticResource RangeButtonStyle}"
                            Tag="OneMinute" />
                        <Button
                            x:Name="FiveMinuteButton"
                            Click="OnRangeClick"
                            Content="5m"
                            Style="{StaticResource RangeButtonStyle}"
                            Tag="FiveMinutes" />
                        <Button
                            x:Name="FifteenMinuteButton"
                            Click="OnRangeClick"
                            Content="15m"
                            Style="{StaticResource RangeButtonStyle}"
                            Tag="FifteenMinutes" />
                        <Button
                            x:Name="OneHourButton"
                            Click="OnRangeClick"
                            Content="1h"
                            Style="{StaticResource RangeButtonStyle}"
                            Tag="OneHour" />
                        <Button
                            x:Name="ExpandButton"
                            Click="OnExpandClick"
                            Content="Expand"
                            Style="{StaticResource GhostButtonStyle}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,18,0,18">
                    <local:WinUiChartSurface
                        x:Name="ChartSurface"
                        Series="{Binding Panel.VisibleSeries, ElementName=Root}"
                        Unit="{Binding Panel.Unit, ElementName=Root}"
                        WindowEndUtc="{Binding Panel.WindowEndUtc, ElementName=Root}"
                        WindowStartUtc="{Binding Panel.WindowStartUtc, ElementName=Root}" />

                    <Canvas
                        Background="Transparent"
                        PointerExited="OnChartPointerExited"
                        PointerMoved="OnChartPointerMoved">
                        <Border
                            x:Name="HoverCard"
                            Background="{ThemeResource SurfaceElevatedBrush}"
                            BorderBrush="{ThemeResource SurfaceStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="12"
                            Visibility="Collapsed">
                            <StackPanel Spacing="6">
                                <TextBlock
                                    x:Name="HoverTimeText"
                                    FontFamily="Bahnschrift"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource TextPrimaryBrush}" />
                                <TextBlock
                                    x:Name="HoverValueText"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextSecondaryBrush}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>
                    </Canvas>
                </Grid>

                <ItemsControl Grid.Row="2" ItemsSource="{Binding Panel.VisibleSeries, ElementName=Root}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapGrid MaximumRowsOrColumns="4" Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,10,6" Padding="0,0,6,0">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse
                                        Width="8"
                                        Height="8"
                                        Margin="0,4,0,0"
                                        Fill="{Binding StrokeBrush}" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextMutedBrush}"
                                        Text="{Binding Name}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Grid>
    </Border>
</UserControl>
